# ─────────────────────────────────────────────────────────────────
# PROMPT GENERATOR — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev.
# In Vercel: add each variable under Project Settings → Environment Variables.
# ALL variables below are required unless marked [OPTIONAL] or [AUTO].
# ─────────────────────────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────────────────────────
# Your Supabase project URL (found in Supabase dashboard → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service role key — used server-side only (API routes), never expose to frontend
# Found in Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase anon (public) key — used by the frontend (Vite)
# Found in Supabase dashboard → Settings → API → anon/public key
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase URL again for the frontend (Vite)
VITE_SUPABASE_URL=https://your-project-id.supabase.co


# ── OPENAI ────────────────────────────────────────────────────────
# OpenAI API key — used for prompt generation (GPT-4o-mini) and image generation (gpt-image-1)
# Found in platform.openai.com → API Keys
OPENAI_API_KEY=sk-...


# ── GOOGLE DRIVE (image storage) ─────────────────────────────────
# The Google Drive folder ID where generated images are saved.
# Get the folder ID from the URL when you open the folder in Google Drive:
# https://drive.google.com/drive/folders/THIS-PART-IS-THE-ID
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# A known Gemini-generated image file ID in Google Drive.
# Used to auto-discover the Gemini images folder.
# Upload any image to your Drive folder and copy its file ID from the sharing URL.
GOOGLE_DRIVE_GEMINI_SAMPLE_FILE_ID=your-sample-file-id


# ── GCP CLOUD RUN (Gemini image generation) ───────────────────────
# The public URL of your Cloud Run service (e.g. https://your-service-xxx-uc.a.run.app)
GCP_CLOUD_RUN_URL=https://your-cloud-run-service-url.a.run.app
CLOUD_RUN_URL=https://your-cloud-run-service-url.a.run.app
NEXT_PUBLIC_IMAGE_API_URL=https://your-cloud-run-service-url.a.run.app

# GCP service account email — used to generate Cloud Run ID tokens
# Format: your-service-account@your-project-id.iam.gserviceaccount.com
GCP_SERVICE_ACCOUNT=your-service-account@your-project-id.iam.gserviceaccount.com

# Workload Identity Federation provider resource name
# Format: projects/PROJECT_NUMBER/locations/global/workloadIdentityPools/POOL/providers/PROVIDER
GCP_WORKLOAD_PROVIDER=projects/123456789/locations/global/workloadIdentityPools/your-pool/providers/your-provider

# GCP project ID (e.g. my-project-123)
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id


# ── GCP OAUTH (Google Drive upload via OAuth — used alongside Workload Identity) ──
# OAuth 2.0 credentials for uploading images to Google Drive from Cloud Run.
# Create in GCP Console → APIs & Services → Credentials → OAuth 2.0 Client ID.
CLOUD_RUN_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
CLOUD_RUN_CLIENT_SECRET=your-oauth-client-secret
CLOUD_RUN_REFRESH_TOKEN=your-oauth-refresh-token


# ── VERCEL (auto-injected — do NOT set manually) ──────────────────
# Vercel injects this automatically when OIDC is enabled.
# Enable in Vercel: Project Settings → Security → Enable Vercel OIDC.
# [AUTO] VERCEL_OIDC_TOKEN — injected per-request by Vercel, never set manually.


